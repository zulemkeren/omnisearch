# OpenAI API key (optional — without it the app uses a high-quality mock response)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the chat model (defaults to gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: override the API base URL — useful for OpenAI-compatible providers
# (Groq, Together, Fireworks, Ollama, LocalAI, self-hosted). Must end with /v1.
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
